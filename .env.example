# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=expense_manager
DB_USER=your_db_user
DB_PASS=your_db_password

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production          # production | development
APP_TIMEZONE=Asia/Dubai
APP_URL=https://yourdomain.com
APP_VERSION=1.0.0           # Increment to bust CSS/JS cache

# ── Email ────────────────────────────────────────────────────────────────────
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=ExpenseMngr

# ── Cron security ────────────────────────────────────────────────────────────
# Random secret to protect cron endpoints if triggered via HTTP (not CLI)
CRON_SECRET=change_me_to_a_long_random_string

# ── Lean Technologies (UAE Open Banking) ─────────────────────────────────────
# Sign up at https://dev.leantech.me to get your app token
# Set LEAN_ENV=production when going live
LEAN_APP_TOKEN=
LEAN_ENV=sandbox            # sandbox | production
# LEAN_WEBHOOK_SECRET=      # Optional: set if Lean provides a separate webhook secret
